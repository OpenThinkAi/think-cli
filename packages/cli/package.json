{
  "name": "@openthink/think",
  "version": "1.10.0",
  "type": "module",
  "description": "Local-first memory for your AI brain — a nervous system that turns engrams into curated, persistent memories in a folder you control. Bundles `think serve` for piping external events (GitHub, Linear, …) into memory.",
  "bin": {
    "think": "dist/index.js"
  },
  "files": [
    "dist",
    "views"
  ],
  "scripts": {
    "build": "tsup && find dist -name '*.js' -exec perl -i -pe 's/from \"sqlite\"/from \"node:sqlite\"/g' {} +",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "homepage": "https://openthink.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenThinkAi/think-cli.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "memory",
    "ai",
    "agents",
    "work-log",
    "local-first",
    "curation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@anthropic-ai/sdk": "^0.81.0",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "hono": "^4.12.15",
    "sqlite-vec": "0.1.9",
    "uuid": "^11.1.0",
    "zod": "^4.4.1"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
